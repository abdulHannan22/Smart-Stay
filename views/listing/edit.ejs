<% layout('/layout/boilerplate') %>
    <div class="row">
        <div class="col-8 offset-2">    
            <br>
            <h2>Edit a Listing</h2>
            <form method="POST" action="/listing/<%= listingdata._id %>?_method=PUT" novalidate class="needs-validation" enctype="multipart/form-data">
                <div class="mb-3 mt-3">
                    <label for="title" class="form-label">Title</label>
                    <input class="form-control" name=listing[title] type="text" value="<%=listingdata.title%>" required/>
                <div class="valid-feedback">looks good!</div>
            </div>
            <div class="mb-3">
                <label for="description" class="form-label">Description</label>
                <textarea class="form-control" name=listing[description]
                type="text" required><%=listingdata.description%></textarea>
                <div class="valid-feedback">looks good!</div>
            </div>
            <div>
                <label for="image" class="form-label">Upload New Image</label>
                <input name=listing[image] class="form-control" type="file" />
            </div>
            <div class="mb-3 col-md-4">
                <label for="price" class="form-label">Price Per Night</label>
                <input required class="form-control" name=listing[price] value="<%=listingdata.price%>" type="text" required/>
                <div class="invalid-feedback">please enter a valid price</div>
            </div>
            <div class="mb-3 col-md-8">
                <label for="location" class="form-label">Location</label>
                <input required class="form-control" name=listing[location] value="<%=listingdata.location%>" type="text" required/>
                <div class="invalid-feedback">please enter a valid country</div>
            </div>
            <div class="mb-3">
                <label for="country" class="form-label">Country</label>
                <input required class="form-control" name=listing[country] value="<%=listingdata.country%>" type="text" required/>
                <div class="invalid-feedback">location should be valid</div>
            </div> 
            <button class="btn btn-dark btn-edit mt-3">Edit</button>
        </form>
    </div>
</div>