<% 
const successMessages = (typeof success !== 'undefined' && success && Array.isArray(success)) ? success : (typeof success !== 'undefined' && success ? [success] : []);
const errorMessages = (typeof error !== 'undefined' && error && Array.isArray(error)) ? error : (typeof error !== 'undefined' && error ? [error] : []);
%>

<% if(successMessages.length > 0){ %>
   <div class="alert alert-success alert-dismissible fade show col-6 offset-3" role="alert">
       <strong>Success!</strong> <%= successMessages.join(", ") %>
       <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
   </div>
<% } %>

<% if(errorMessages.length > 0){ %>
   <div class="alert alert-danger alert-dismissible fade show col-6 offset-3" role="alert">
       <strong>Error!</strong> <%= errorMessages.join(", ") %>
       <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
   </div>
<% } %>